# ═══════════════════════════════════════════════════════════════
# SwitchAI Backend — Variabili d'ambiente
# Copia questo file in .env e imposta i valori reali.
# .env NON va MAI committato (è in .gitignore).
# ═══════════════════════════════════════════════════════════════

# Email a cui arrivano le notifiche di attivazione
ACTIVATION_EMAIL=attivazioni@tuodominio.it

# API Key per endpoint trigger-scraper (genera con: openssl rand -hex 32)
API_KEY=cambiami-con-una-stringa-lunga-e-casuale

# Web Service per invio sottoscrizioni
WS_SUBSCRIPTION_URL=<url-web-service>
WS_SUBSCRIPTION_TOKEN=<token-web-service>
