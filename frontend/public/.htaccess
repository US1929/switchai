<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  DirectorySlash Off

  # Forza HTTPS + www (singolo redirect, non due)
  RewriteCond %{HTTPS} off [OR]
  RewriteCond %{HTTP_HOST} !^www\. [NC]
  RewriteRule ^(.*)$ https://www.switchai.it/$1 [R=301,L]

  # ═══════════════════════════════════════════════════════
  # 1. FILE STATICI — serviti direttamente (PRIMA di tutto)
  # ═══════════════════════════════════════════════════════
  RewriteRule ^llms\.txt$ - [L,NC]
  RewriteRule ^llm\.txt$ /llms.txt [R=301,L]
  RewriteRule ^webmcp\.json$ - [L,NC]
  RewriteRule ^\.well-known/ - [L,NC]
  # Sitemap generata dinamicamente (via PHP, sempre aggiornata)
  RewriteRule ^sitemap\.xml$ api/index.php [QSA,L]
  RewriteRule ^robots\.txt$ - [L,NC]
  RewriteRule ^openapi\.json$ - [L,NC]
  RewriteRule ^icons\.svg$ - [L,NC]
  RewriteRule ^favicon\.svg$ - [L,NC]
  RewriteRule ^index\.html$ - [L,NC]
  # Redirect .html → URL pulito (301) — DEVE stare PRIMA dei passthrough!
  # %{THE_REQUEST} = richiesta HTTP originale, immutata dai rewrite interni
  # I rewrite interni (clean→.html) NON triggerano queste regole → niente loop
  RewriteCond %{THE_REQUEST} \.html
  RewriteRule ^come-funziona\.html$ /come-funziona [R=301,L]
  RewriteCond %{THE_REQUEST} \.html
  RewriteRule ^per-llm\.html$ /per-llm [R=301,L]
  RewriteCond %{THE_REQUEST} \.html
  RewriteRule ^privacy\.html$ /privacy [R=301,L]
  RewriteCond %{THE_REQUEST} \.html
  RewriteRule ^cookie\.html$ /cookie [R=301,L]
  RewriteCond %{THE_REQUEST} \.html
  RewriteRule ^faq\.html$ /faq [R=301,L]
  RewriteCond %{THE_REQUEST} \.html
  RewriteRule ^mcp\.html$ /faq [R=301,L]

  # File HTML statici — serviti dopo redirect o rewrite interno
  RewriteRule ^per-llm\.html$ - [L,NC]
  RewriteRule ^privacy\.html$ - [L,NC]
  RewriteRule ^come-funziona\.html$ - [L,NC]
  RewriteRule ^cookie\.html$ - [L,NC]
  RewriteRule ^faq\.html$ - [L,NC]

  # URL puliti → servono internamente il file .html (rewrite silenzioso)
  RewriteRule ^come-funziona$ /come-funziona.html [L]
  RewriteRule ^per-llm$ /per-llm.html [L]
  RewriteRule ^privacy$ /privacy.html [L]
  RewriteRule ^cookie$ /cookie.html [L]
  RewriteRule ^faq$ /faq.html [L]
  RewriteRule ^connettori$ /faq.html [L]

  # Redirect trailing slash → clean (evita SPA fallback con canonical sbagliato)
  RewriteRule ^come-funziona/$ /come-funziona [R=301,L]
  RewriteRule ^per-llm/$ /per-llm [R=301,L]
  RewriteRule ^privacy/$ /privacy [R=301,L]
  RewriteRule ^cookie/$ /cookie [R=301,L]
  RewriteRule ^faq/$ /faq [R=301,L]
  RewriteRule ^connettori$ /faq.html [L]

  # Pagine offerta generate dinamicamente (per crawler/SEO)
  RewriteRule ^offerta/([a-zA-Z0-9\-]+)$ api/index.php [QSA,L]

  # Risorse SEO — pagine PHP indicizzabili (router dedicato)
  RewriteRule ^risorse(/.*)?$ risorse.php [QSA,L]

  # MCP Server pubblico (JSON-RPC via HTTP POST)
  RewriteRule ^mcp/?$ mcp/index.php [QSA,L]

  # ═══════════════════════════════════════════════════════
  # 2. PROTEZIONE — blocca accesso a path interni e file sensibili
  # ═══════════════════════════════════════════════════════
  RewriteRule ^inc/ - [R=404,L]
  RewriteRule ^data/ - [R=404,L]
  RewriteRule ^logs/ - [R=404,L]
  # Blocca file nascosti (.env, .git, etc.) — sicurezza critica
  RewriteRule ^\.env - [R=404,L]
  RewriteRule ^\. - [R=404,L]

  # ═══════════════════════════════════════════════════════
  # 3. API — instrada a api/index.php
  # ═══════════════════════════════════════════════════════
  RewriteRule ^api(/.*)?$ api/index.php [QSA,L]

  # ═══════════════════════════════════════════════════════
  # 4. FILE ESISTENTI — se il file esiste su disco, servilo
  # ═══════════════════════════════════════════════════════
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule ^ - [L]

  # ═══════════════════════════════════════════════════════
  # 5. SPA FALLBACK — tutto il resto → index.html
  # ═══════════════════════════════════════════════════════
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-l
  RewriteRule . /index.html [L]
</IfModule>

# Blocca accesso HTTP a file nascosti — sicurezza critica (.env, .git, etc.)
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# Server-Side Includes per file .html (nav centralizzata)
# -MultiViews è CRITICO: senza, Apache serve /pagina → pagina.html senza redirect,
# creando un conflitto di canonical (URL servito ≠ canonical nell'HTML).
Options +Includes -MultiViews
AddOutputFilter INCLUDES .html

# Forza UTF-8 su tutti i file
# MIME type per JavaScript modules (.mjs)
<IfModule mod_mime.c>
  AddType application/javascript .mjs
</IfModule>

AddDefaultCharset UTF-8

# CORS per file statici di discovery (JSON, TXT, XML — serviti senza PHP)
# NOTA: i .php (API, MCP) gestiscono CORS autonomamente — NON duplicare gli header
<IfModule mod_headers.c>
  <FilesMatch "\.(json|txt|xml)$">
    Header set Access-Control-Allow-Origin "*"
    Header set Access-Control-Allow-Methods "GET, OPTIONS"
  </FilesMatch>
</IfModule>

# Forza contenuto fresco per HTML (evita cache stale su proxy LLM)
<IfModule mod_headers.c>
  <FilesMatch "\.(html|txt|xml|json)$">
    Header set Cache-Control "public, max-age=3600, must-revalidate"
    Header set Vary "User-Agent, Accept-Encoding"
  </FilesMatch>
</IfModule>

# Cache immagini (1 anno — cambiano raramente)
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
</IfModule>

# Cache per assets statici
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
</IfModule>
