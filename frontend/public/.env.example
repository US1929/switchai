# ═══════════════════════════════════════════════════════════════
# SwitchAI — Variabili d'ambiente (TEMPLATE)
# Copiare in .env e inserire i valori reali prima del deploy.
# .env NON va committato (è in .gitignore).
# ═══════════════════════════════════════════════════════════════

# Fonti dati tariffe (URL privati — NON committare i valori reali)
LUCE_JSON_URL=<url-db-offerte-luce>
GAS_JSON_URL=<url-db-offerte-gas>

ACTIVATION_EMAIL=attivazioni@switchai.it
API_KEY=<genera-con-openssl-rand-hex-32>
WS_SUBSCRIPTION_TOKEN=<token-web-service>
WS_SUBSCRIPTION_URL=<url-web-service>
WS_ENABLED=false
STATS_USER=admin
STATS_PASSWORD_HASH=<generato-con-php-password_hash>
